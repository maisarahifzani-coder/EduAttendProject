<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F6FA">

    <!-- ================= HEADER ================= -->
    <LinearLayout
        android:id="@+id/headerAdmin"
        android:layout_width="0dp"
        android:layout_height="180dp"
        android:orientation="vertical"
        android:padding="24dp"
        android:background="@drawable/bg_red_gradient"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:id="@+id/tvWelcome"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Welcome, Admin"
            android:textColor="@android:color/white"
            android:textSize="22sp"
            android:textStyle="bold"/>

        <TextView
            android:id="@+id/tvSubtitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Dashboard Overview"
            android:textColor="@android:color/white"
            android:textSize="14sp"
            android:layout_marginTop="4dp"/>

    </LinearLayout>

    <!-- ================= CONTENT ================= -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintTop_toBottomOf="@id/headerAdmin"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <!-- ================= SECTION 1 ================= -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Overview"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="#2C3E50"
                android:layout_marginBottom="16dp"/>

            <GridLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:columnCount="2"
                android:rowCount="2"
                android:useDefaultMargins="true">

                <!-- Total Students -->
                <androidx.cardview.widget.CardView
                    android:layout_width="0dp"
                    android:layout_height="120dp"
                    android:layout_columnWeight="1"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="6dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="vertical"
                        android:gravity="center">

                        <TextView
                            android:id="@+id/tvTotalStudents"
                            android:text="520"
                            android:textSize="22sp"
                            android:textStyle="bold"
                            android:layout_height="wrap_content"
                            android:layout_width="match_parent"
                            android:textColor="#E53935"/>

                        <TextView
                            android:text="Total Students"
                            android:layout_height="wrap_content"
                            android:layout_width="match_parent"
                            android:textSize="14sp"/>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- Total Lecturers -->
                <androidx.cardview.widget.CardView
                    android:layout_width="0dp"
                    android:layout_height="120dp"
                    android:layout_columnWeight="1"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="6dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="vertical"
                        android:gravity="center">

                        <TextView
                            android:id="@+id/tvTotalLecturers"
                            android:text="206"
                            android:textSize="22sp"
                            android:layout_height="wrap_content"
                            android:layout_width="match_parent"
                            android:textStyle="bold"
                            android:textColor="#E53935"/>

                        <TextView
                            android:text="Total Lecturers"
                            android:layout_height="wrap_content"
                            android:layout_width="match_parent"
                            android:textSize="14sp"/>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- Total Classes -->
                <androidx.cardview.widget.CardView
                    android:layout_width="0dp"
                    android:layout_height="120dp"
                    android:layout_columnWeight="1"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="6dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="vertical"
                        android:gravity="center">

                        <TextView
                            android:id="@+id/tvTotalClasses"
                            android:text="25"
                            android:textSize="22sp"
                            android:layout_height="wrap_content"
                            android:layout_width="match_parent"
                            android:textStyle="bold"
                            android:textColor="#E53935"/>

                        <TextView
                            android:text="Total Classes"
                            android:layout_height="wrap_content"
                            android:layout_width="match_parent"
                            android:textSize="14sp"/>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- Attendance -->
                <androidx.cardview.widget.CardView
                    android:layout_width="0dp"
                    android:layout_height="120dp"
                    android:layout_columnWeight="1"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="6dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="vertical"
                        android:gravity="center">

                        <TextView
                            android:id="@+id/tvAttendance"
                            android:text="93%"
                            android:textSize="22sp"
                            android:layout_height="wrap_content"
                            android:layout_width="match_parent"
                            android:textStyle="bold"
                            android:textColor="#E53935"/>

                        <TextView
                            android:text="Today Attendance"
                            android:layout_height="wrap_content"
                            android:layout_width="match_parent"
                            android:textSize="14sp"/>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

            </GridLayout>

            <!-- ================= SECTION 2 ================= -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Management"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="#2C3E50"
                android:layout_marginTop="30dp"
                android:layout_marginBottom="16dp"/>

            <!-- Manage Student -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnManageStudent"
                android:layout_width="match_parent"
                android:layout_height="55dp"
                android:text="Manage Student"
                android:textAllCaps="false"
                android:textSize="16sp"
                android:backgroundTint="#E53935"
                android:textColor="@android:color/white"
                app:cornerRadius="12dp"
                android:layout_marginBottom="12dp"/>

            <!-- Manage Lecturer -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnManageLecturer"
                android:layout_width="match_parent"
                android:layout_height="55dp"
                android:text="Manage Lecturer"
                android:textAllCaps="false"
                android:textSize="16sp"
                android:backgroundTint="#E53935"
                android:textColor="@android:color/white"
                app:cornerRadius="12dp"
                android:layout_marginBottom="12dp"/>

            <!-- Manage Timetable -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnManageTimetable"
                android:layout_width="match_parent"
                android:layout_height="55dp"
                android:text="Manage Timetable"
                android:textAllCaps="false"
                android:textSize="16sp"
                android:backgroundTint="#E53935"
                android:textColor="@android:color/white"
                app:cornerRadius="12dp"/>

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>